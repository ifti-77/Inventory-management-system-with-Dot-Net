
<h1>Manage Product</h1>
<div>
    <button class="btn-outline-primary" onclick="location.href = '@Url.Action("CreateProduct")'">Create Product</button>
</div>

@if(Model.Count == 0)
{
    <p>No products found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Stock Quantity</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>BDT @product.Price.ToString()</td>
                    <td>@product.Quantity</td>
                    <td>
                        <button class="btn-outline-secondary" onclick="location.href = '@Url.Action("UpdateProduct",new {product.Id})'">Edit</button>
                        <form action="DeleteProduct" method="post">
                            <input type="hidden" name="Id" value="@product.Id" />
                            <button class="btn-outline-danger" type="submit">Delete</button>
                        </form>
                    </td>   
                </tr>
            }
        </tbody>
    </table>
}
