

@if(Model != null){
    <form asp-action="UpdateProduct" method="post">
        
        <div class="form-group">
            <label for="Id"></label>
            <input name="Id" class="form-control" type="text" value="@Model.Id" disabled/>
        </div>

        <div class="form-group">
            <label for="Name"></label>
            <input name="Name" class="form-control" type="text" value="@Model.Name"/>
            <span name="Name" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label for="Sku"></label>
            <input name="Sku" class="form-control" type="text" value="@Model.Sku" />
            <span name="Sku" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label for="Quantity"></label>
            <input name="Quantity" class="form-control" type="number" value="@Model.Quantity" />
            <span name="Quantity" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label for="Price"></label>
            <input name="Price" class="form-control" type="number" value="@Model.Price" />
            <span name="Price" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Create</button>
    </form>
}else
{
    <p>No Product found</p>
}